# ---------------------------------------------------------------------------
# Replay Party — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com os valores reais.
# (.env.local NÃO vai para o git.)
# ---------------------------------------------------------------------------

# Banco de dados — Supabase
# Onde achar: supabase.com -> seu projeto -> Project Settings -> Database
#  - Para o app (runtime): use a Connection string do POOLER (Transaction, porta 6543)
#  - Para migrations (drizzle-kit): use a conexão DIRECT (porta 5432)
DATABASE_URL="postgresql://postgres.[ref]:[SENHA]@[host]:6543/postgres"
DIRECT_URL="postgresql://postgres.[ref]:[SENHA]@[host]:5432/postgres"

# Mercado Pago — credenciais de TESTE
# Onde achar: developers.mercadopago.com.br -> Suas integrações -> sua app -> Credenciais de teste
MP_ACCESS_TOKEN="TEST-xxxxxxxxxxxx"
NEXT_PUBLIC_MP_PUBLIC_KEY="TEST-xxxxxxxxxxxx"

# Segredo do webhook (entra na fase de produção)
MP_WEBHOOK_SECRET=""

# URL base do site (para montar os links dos ingressos)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Senha de acesso à tela de check-in (portaria)
CHECKIN_PASSWORD="troque-esta-senha"

# E-mail (Resend) — opcional. resend.com -> API Keys
RESEND_API_KEY=""
EMAIL_FROM="Replay Party <onboarding@resend.dev>"
